# MB_N2N BrickGame - Project-Scoped Daemon Config
# ================================================
# 이 파일은 AC247 데몬이 --project-dir로 이 프로젝트를 실행할 때 로드됨.
# AC247 글로벌 .env 위에 오버라이드됨 (프로젝트별 격리).

# AUTHENTICATION (REQUIRED)
# AC247 글로벌 .env 대신 여기에 설정하면 이 프로젝트에만 적용됨.
# CLAUDE_CODE_OAUTH_TOKEN=your-project-specific-token-here

# Model
AUTO_BUILD_MODEL=claude-opus-4-6

# MCP Servers (이 프로젝트에서 사용할 MCP)
MCP_SERVERS=context7,mcp-unity

# Graphiti (disabled - needs OpenAI key)
GRAPHITI_ENABLED=false
